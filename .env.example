# Neon Postgres (free tier)
DATABASE_URL=

# LLM provider API keys (set only the ones you use)
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
AI_GATEWAY_API_KEY=
OPENAI_COMPATIBLE_API_KEY=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Admin auth (single admin secret; see spec §15)
ADMIN_SECRET=

# Cron auth (Vercel auto-sends `Authorization: Bearer <CRON_SECRET>` to cron paths)
CRON_SECRET=

# Optional fallback transcript source
TUSHARE_TOKEN=
